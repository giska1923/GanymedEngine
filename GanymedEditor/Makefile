GENERATED :=
OBJECTS :=

GENERATED += $(OBJDIR)/EditorLayer.o
GENERATED += $(OBJDIR)/GanymedEditorApp.o
GENERATED += $(OBJDIR)/SceneHierarchyPanel.o
OBJECTS += $(OBJDIR)/EditorLayer.o
OBJECTS += $(OBJDIR)/GanymedEditorApp.o
